<?xml version='1.0' encoding='windows-1252'?>
<!--
  KitsuneEngine Windows Installer — WiX 3 definition
  Build with:  cargo wix -p kitsune-ui --no-build --nocapture
  Or use the helper:  .\build-installer.ps1
-->

<?if $(sys.BUILDARCH) = x64 or $(sys.BUILDARCH) = arm64 ?>
    <?define PlatformProgramFilesFolder = "ProgramFiles64Folder" ?>
<?else ?>
    <?define PlatformProgramFilesFolder = "ProgramFilesFolder" ?>
<?endif ?>

<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

    <Product
        Id='*'
        Name='KitsuneEngine'
        UpgradeCode='36AF82A6-D485-4F10-8DE6-4576BD710E70'
        Manufacturer='Kitsune Team'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package Id='*'
            Keywords='Installer'
            Description='KitsuneEngine — AI-native privacy browser built in Rust'
            Manufacturer='Kitsune Team'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252'
            />

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            DowngradeErrorMessage='A newer version of KitsuneEngine is already installed. Setup will now exit.'/>

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1'/>
        <Property Id='DiskPrompt' Value='KitsuneEngine Installation'/>

        <!-- ── Branding ─────────────────────────────────────── -->
        <Icon Id='KitsuneICO' SourceFile='kitsune.ico'/>
        <Property Id='ARPPRODUCTICON'  Value='KitsuneICO'/>
        <Property Id='ARPHELPLINK'     Value='https://kengine.tech'/>
        <Property Id='ARPURLINFOABOUT' Value='https://kengine.tech'/>

        <!-- ── Launch after install checkbox ─────────────────── -->
        <Property Id='WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT' Value='Launch KitsuneEngine'/>
        <Property Id='WixShellExecTarget' Value='[APPLICATIONFOLDER]bin\kitsune.exe'/>
        <CustomAction Id='LaunchApplication'
            BinaryKey='WixCA' DllEntry='WixShellExec' Impersonate='yes'/>

        <!-- ── Directory tree ────────────────────────────────── -->
        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='$(var.PlatformProgramFilesFolder)' Name='PFiles'>
                <Directory Id='APPLICATIONFOLDER' Name='KitsuneEngine'>

                    <!-- License sidecar -->
                    <Component Id='License' Guid='*'>
                        <File Id='LicenseFile'
                            DiskId='1'
                            Source='wix\License.rtf'
                            KeyPath='yes'/>
                    </Component>

                    <Directory Id='Bin' Name='bin'>
                        <!-- PATH entry (optional feature) -->
                        <Component Id='Path' Guid='3631C19F-A173-4958-B837-BD84CE115764' KeyPath='yes'>
                            <Environment
                                Id='PATH'
                                Name='PATH'
                                Value='[Bin]'
                                Permanent='no'
                                Part='last'
                                Action='set'
                                System='yes'/>
                        </Component>

                        <!-- Main executable + shortcuts -->
                        <Component Id='binary0' Guid='*'>
                            <File
                                Id='exe0'
                                Name='kitsune.exe'
                                DiskId='1'
                                Source='$(var.CargoTargetBinDir)\kitsune.exe'
                                KeyPath='yes'>
                                <!-- Desktop shortcut -->
                                <Shortcut
                                    Id='desktopShortcut'
                                    Directory='DesktopFolder'
                                    Name='KitsuneEngine'
                                    WorkingDirectory='Bin'
                                    Icon='KitsuneICO'
                                    IconIndex='0'
                                    Advertise='no'/>
                                <!-- Start Menu shortcut -->
                                <Shortcut
                                    Id='startMenuShortcut'
                                    Directory='KitsuneStartMenuDir'
                                    Name='KitsuneEngine'
                                    WorkingDirectory='Bin'
                                    Icon='KitsuneICO'
                                    IconIndex='0'
                                    Advertise='no'/>
                            </File>
                        </Component>
                    </Directory>
                </Directory>
            </Directory>

            <!-- Desktop folder reference -->
            <Directory Id='DesktopFolder' Name='Desktop'/>

            <!-- Start Menu folder -->
            <Directory Id='ProgramMenuFolder' Name='Programs'>
                <Directory Id='KitsuneStartMenuDir' Name='KitsuneEngine'>
                    <Component Id='KitsuneStartMenuComp' Guid='*'>
                        <RemoveFolder Id='RemoveKitsuneStartMenuDir'
                            Directory='KitsuneStartMenuDir' On='uninstall'/>
                        <RegistryValue
                            Root='HKCU'
                            Key='Software\KitsuneEngine'
                            Name='installed'
                            Type='integer'
                            Value='1'
                            KeyPath='yes'/>
                    </Component>
                </Directory>
            </Directory>
        </Directory>

        <!-- ── Feature tree ──────────────────────────────────── -->
        <Feature
            Id='Binaries'
            Title='KitsuneEngine'
            Description='Installs the KitsuneEngine browser, desktop shortcut, and license.'
            Level='1'
            ConfigurableDirectory='APPLICATIONFOLDER'
            AllowAdvertise='no'
            Display='expand'
            Absent='disallow'>

            <ComponentRef Id='License'/>
            <ComponentRef Id='binary0'/>
            <ComponentRef Id='KitsuneStartMenuComp'/>

            <Feature
                Id='Environment'
                Title='Add to PATH'
                Description='Add the KitsuneEngine install directory to the system PATH, so you can run &quot;kitsune&quot; from any terminal.'
                Level='1'
                Absent='allow'>
                <ComponentRef Id='Path'/>
            </Feature>
        </Feature>

        <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>

        <!-- ── UI ────────────────────────────────────────────── -->
        <UI>
            <UIRef Id='WixUI_FeatureTree'/>
            <!-- Launch on finish -->
            <Publish
                Dialog='ExitDialog'
                Control='Finish'
                Event='DoAction'
                Value='LaunchApplication'>
                WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed
            </Publish>
        </UI>

        <WixVariable Id='WixUILicenseRtf' Value='wix\License.rtf'/>

    </Product>

</Wix>
